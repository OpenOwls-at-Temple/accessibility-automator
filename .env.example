# ── Accessibility Automator — example environment ──
# Copy to .env and fill in real values. NEVER commit a real .env.

# LLM (OpenAI-compatible endpoint; provider/model swappable)
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Auth — Google SSO + admin-managed allowlist (see ai_specs/deployment.md).
# GOOGLE_CLIENT_ID is the Google OAuth *web* client ID (same value the frontend
# uses as VITE_GOOGLE_CLIENT_ID). Sign-in is restricted to ALLOWED_EMAIL_DOMAIN
# AND to accounts an admin has added. Leave GOOGLE_CLIENT_ID blank locally to
# use the dev-login box instead.
GOOGLE_CLIENT_ID=
ALLOWED_EMAIL_DOMAIN=temple.edu
JWT_SECRET=change-me-to-a-long-random-string

# Database — only the user allowlist lives here (SQLite locally, Supabase
# Postgres in production). Everything else stays on the filesystem.
DATABASE_URL=sqlite:///./a11y.db

# Storage + URLs
STORAGE_DIR=./storage
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# local | production  (production disables the /auth/dev-login endpoint)
ENVIRONMENT=local
