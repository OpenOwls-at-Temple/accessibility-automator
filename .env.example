# ── Accessibility Automator — example environment ──
# Copy to .env and fill in real values. NEVER commit a real .env.

# LLM — two providers supported, auto-detected from LLM_BASE_URL:
#
# Option A: Anthropic (Claude / Fable 5) ← recommended
LLM_API_KEY=sk-ant-your-key-here
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-fable-5
#
# Option B: OpenAI-compatible (OpenAI, Groq, Ollama, etc.)
# LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Auth: "mock" for local dev, "azure" for production
AUTH_PROVIDER=mock

# Azure AD / Temple SSO (production only)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=

# Session signing + storage
SESSION_SECRET=change-me-in-production
STORAGE_DIR=./storage

# CORS + environment
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=local
